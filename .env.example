# Laravel Accounting Package — Development Environment
# Copy this file to .env before running docker compose:
#   cp .env.example .env
# Then generate an application key:
#   php artisan key:generate

APP_ENV=local
APP_DEBUG=true
APP_KEY=

# Database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=accounting
DB_USERNAME=sail
DB_PASSWORD=

# Accounting package
ACCOUNTING_BASE_CURRENCY=USD
